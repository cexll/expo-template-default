{
  "name": "expo-template-default",
  "license": "0BSD",
  "main": "expo-router/entry",
  "version": "55.1.21",
  "engines": {
    "node": "20.x"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "serve": "expo serve",
    "prebuild": "expo prebuild",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "build:preview:ios": "eas build -p ios --profile preview",
    "build:preview:android": "eas build -p android --profile preview",
    "build:production": "eas build --profile production",
    "deploy:web": "expo export --platform web && eas deploy",
    "update:preview": "eas update --branch preview",
    "update:production": "eas update --branch production",
    "prepare": "husky",
    "check": "npm run lint && npm run typecheck",
    "reset-project": "node ./scripts/reset-project.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "node ./node_modules/eslint/bin/eslint.js --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "node ./node_modules/prettier/bin/prettier.cjs --check"
    ]
  },
  "dependencies": {
    "@expo/cli": "^55.0.23",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.90.5",
    "clsx": "^2.1.1",
    "expo": "~55.0.14",
    "expo-constants": "~55.0.13",
    "expo-device": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.12",
    "expo-linking": "~55.0.12",
    "expo-modules-core": "~55.0.22",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-server": "~55.0.7",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.17",
    "expo-sqlite": "^55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "nativewind": "^5.0.0-preview.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-css": "^3.0.7",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.15",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  }
}
